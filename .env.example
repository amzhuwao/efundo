# Copy to apps/api/.env and apps/web/.env.local

# Database (native PostgreSQL — required)
DATABASE_URL=postgresql://efundo:efundo@localhost:5432/efundo?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Object storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=efundo
S3_SECRET_KEY=efundominio
S3_BUCKET=efundo-resources
S3_REGION=us-east-1

# API
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SITE_URL=https://efundo.co.zw

# AI (Google Gemini — free tier at aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_MAX_SOURCE_CHARS=120000
GEMINI_MAX_INLINE_MB=20

# Google AdSense (add after approval)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
