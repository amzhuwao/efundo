generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_ADMIN
  LECTURER
  MODERATOR
  STUDENT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ResourceType {
  PAST_PAPER
  TEXTBOOK
  LECTURE_NOTE
  ASSIGNMENT
  SOLUTION
  RESEARCH_PAPER
  LAB_MANUAL
  REVISION_GUIDE
  SLIDES
  CASE_STUDY
  EXTERNAL_COURSE
}

enum ResourceStatus {
  DRAFT
  PENDING
  APPROVED
  PUBLISHED
  REJECTED
}

enum EducationLevel {
  PRIMARY
  O_LEVEL
  A_LEVEL
  TERTIARY
  OTHER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  fullName       String          @map("full_name")
  role           UserRole        @default(STUDENT)
  status         UserStatus      @default(PENDING)
  avatarUrl      String?         @map("avatar_url")
  educationLevel EducationLevel? @map("education_level")
  programId      String?         @map("program_id")
  year           Int?
  emailVerified  Boolean         @default(false) @map("email_verified")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  program           Program?      @relation(fields: [programId], references: [id])
  favouriteSubjects UserSubject[]
  uploadedResources Resource[]    @relation("UploadedResources")
  bookmarks         Bookmark[]
  downloads         Download[]
  reviews           Review[]
  lessonProgress    LessonProgress[]
  discussions       Discussion[]  @relation("DiscussionAuthor")
  comments          Comment[]
  createdLessons    Lesson[]      @relation("LessonAuthor")
  lessonAiProjects  LessonAiProject[]
  aiAssistantSessions AiAssistantSession[]
  questions         Question[]
  quizzes           Quiz[]
  quizAttempts      QuizAttempt[]
  quizCertificates  QuizCertificate[]

  @@index([programId])
  @@index([educationLevel])
  @@map("users")
}

model Program {
  id            String         @id @default(cuid())
  level         EducationLevel
  name          String
  slug          String
  description   String?
  providerName  String?        @map("provider_name")
  formOrGrade   Int?           @map("form_or_grade")
  durationYears Int?           @map("duration_years")
  orderIndex    Int            @default(0) @map("order_index")
  status        String         @default("active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  subjects  Subject[]
  users     User[]
  resources Resource[]

  @@unique([level, slug])
  @@index([level])
  @@map("programs")
}

model Subject {
  id        String   @id @default(cuid())
  programId String   @map("program_id")
  name      String
  code      String
  year      Int?
  semester  Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  program     Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  users       UserSubject[]
  resources   Resource[]
  modules     Module[]
  discussions Discussion[]
  aiProjects  LessonAiProject[]
  aiAssistantSessions AiAssistantSession[]
  questions   Question[]
  quizzes     Quiz[]

  @@unique([programId, code])
  @@index([programId])
  @@index([year])
  @@map("subjects")
}

model UserSubject {
  userId    String   @map("user_id")
  subjectId String   @map("subject_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([userId, subjectId])
  @@map("user_subjects")
}

model Resource {
  id              String         @id @default(cuid())
  title           String
  slug            String
  description     String?
  type            ResourceType
  status          ResourceStatus @default(DRAFT)
  educationLevel EducationLevel? @map("education_level")
  programId      String?         @map("program_id")
  subjectId      String?         @map("subject_id")
  year            Int?
  semester        Int?
  author          String?
  uploaderId      String?        @map("uploader_id")
  fileKey         String?        @map("file_key")
  fileName        String?        @map("file_name")
  fileSize        Int?           @map("file_size")
  mimeType        String?        @map("mime_type")
  downloadCount   Int            @default(0) @map("download_count")
  viewCount       Int            @default(0) @map("view_count")
  tags            String[]       @default([])
  externalUrl     String?        @map("external_url")
  sourceName      String?        @map("source_name")
  sourceCatalogUrl String?       @map("source_catalog_url")
  attributionNotice String?     @map("attribution_notice")
  durationWeeks   Int?           @map("duration_weeks")
  rejectionReason String?        @map("rejection_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  publishedAt     DateTime?      @map("published_at")

  program   Program? @relation(fields: [programId], references: [id])
  subject   Subject? @relation(fields: [subjectId], references: [id])
  uploader  User?    @relation("UploadedResources", fields: [uploaderId], references: [id])
  bookmarks Bookmark[]
  downloads Download[]
  reviews   Review[]

  @@unique([programId, slug])
  @@index([programId])
  @@index([educationLevel])
  @@index([subjectId])
  @@index([type])
  @@index([status])
  @@index([title])
  @@map("resources")
}

model Bookmark {
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([userId, resourceId])
  @@map("bookmarks")
}

model Download {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  resourceId   String   @map("resource_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
  @@map("downloads")
}

model Review {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
  @@map("reviews")
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Module {
  id          String   @id @default(cuid())
  subjectId   String   @map("subject_id")
  title       String
  slug        String
  description String?
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics  Topic[]

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@map("modules")
}

model Topic {
  id          String   @id @default(cuid())
  moduleId    String   @map("module_id")
  title       String
  slug        String
  description String?
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  module  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  questions Question[]

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@map("topics")
}

model Lesson {
  id              String       @id @default(cuid())
  topicId         String       @map("topic_id")
  title           String
  slug            String
  summary         String?
  content         Json         @default("[]")
  videoUrl        String?      @map("video_url")
  videoKey        String?      @map("video_key")
  videoFileName   String?      @map("video_file_name")
  videoMimeType   String?      @map("video_mime_type")
  videoSize       Int?         @map("video_size")
  durationMinutes Int          @default(15) @map("duration_minutes")
  difficulty      Difficulty   @default(BEGINNER)
  objectives      String[]     @default([])
  prerequisites   String[]     @default([])
  status          LessonStatus @default(DRAFT)
  orderIndex      Int          @default(0) @map("order_index")
  authorId        String?      @map("author_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  publishedAt     DateTime?    @map("published_at")

  topic    Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author   User?            @relation("LessonAuthor", fields: [authorId], references: [id])
  progress LessonProgress[]

  aiAssistantSessions AiAssistantSession[]

  @@unique([topicId, slug])
  @@index([topicId])
  @@index([status])
  @@map("lessons")
}

model LessonProgress {
  userId          String   @map("user_id")
  lessonId        String   @map("lesson_id")
  percentComplete Int      @default(0) @map("percent_complete")
  lastPosition    Int      @default(0) @map("last_position")
  completed       Boolean  @default(false)
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([userId, lessonId])
  @@map("lesson_progress")
}

model Discussion {
  id        String   @id @default(cuid())
  subjectId String   @map("subject_id")
  authorId  String   @map("author_id")
  title     String
  body      String
  isPinned  Boolean  @default(false) @map("is_pinned")
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subject  Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  author   User      @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([subjectId])
  @@index([createdAt])
  @@map("discussions")
}

model Comment {
  id           String   @id @default(cuid())
  discussionId String   @map("discussion_id")
  authorId     String   @map("author_id")
  body         String
  isAccepted   Boolean  @default(false) @map("is_accepted")
  upvotes      Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@map("comments")
}

enum AiProjectStatus {
  DRAFT
  PROCESSING
  READY
  APPLIED
  FAILED
}

enum AiSourceStatus {
  PENDING
  EXTRACTING
  READY
  FAILED
}

enum AiSourceType {
  PDF
  VIDEO
  TEXT
}

model LessonAiProject {
  id               String          @id @default(cuid())
  subjectId        String          @map("subject_id")
  title            String
  instructions     String?
  status           AiProjectStatus @default(DRAFT)
  generatedOutline Json?           @map("generated_outline")
  errorMessage     String?         @map("error_message")
  authorId         String          @map("author_id")
  appliedAt        DateTime?       @map("applied_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  subject Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sources LessonAiSource[]

  @@index([subjectId])
  @@index([authorId])
  @@index([status])
  @@map("lesson_ai_projects")
}

model LessonAiSource {
  id            String         @id @default(cuid())
  projectId     String         @map("project_id")
  title         String
  type          AiSourceType
  fileKey       String?        @map("file_key")
  fileName      String?        @map("file_name")
  mimeType      String?        @map("mime_type")
  fileSize      Int?           @map("file_size")
  extractedText String?        @map("extracted_text") @db.Text
  status        AiSourceStatus @default(PENDING)
  errorMessage  String?        @map("error_message")
  orderIndex    Int            @default(0) @map("order_index")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  project LessonAiProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("lesson_ai_sources")
}

enum AiChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model AiAssistantSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  subjectId String?  @map("subject_id")
  lessonId  String?  @map("lesson_id")
  title     String   @default("New conversation")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject  Subject?             @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  lesson   Lesson?              @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  messages AiAssistantMessage[]
  files    AiAssistantFile[]

  @@index([userId])
  @@index([subjectId])
  @@index([lessonId])
  @@map("ai_assistant_sessions")
}

model AiAssistantMessage {
  id        String     @id @default(cuid())
  sessionId String     @map("session_id")
  role      AiChatRole
  content   String     @db.Text
  createdAt DateTime   @default(now()) @map("created_at")

  session AiAssistantSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_assistant_messages")
}

model AiAssistantFile {
  id            String         @id @default(cuid())
  sessionId     String         @map("session_id")
  fileName      String         @map("file_name")
  fileKey       String         @map("file_key")
  mimeType      String         @map("mime_type")
  fileSize      Int            @map("file_size")
  extractedText String?        @map("extracted_text") @db.Text
  status        AiSourceStatus @default(PENDING)
  errorMessage  String?        @map("error_message")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  session AiAssistantSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_assistant_files")
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  FILL_BLANK
  ESSAY
}

enum QuestionStatus {
  DRAFT
  PUBLISHED
}

enum QuizType {
  PRACTICE
  MOCK_EXAM
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

model Question {
  id            String         @id @default(cuid())
  subjectId     String         @map("subject_id")
  topicId       String?        @map("topic_id")
  type          QuestionType
  stem          String         @db.Text
  options       Json?
  correctAnswer Json           @map("correct_answer")
  explanation   String?        @db.Text
  difficulty    Difficulty     @default(BEGINNER)
  tags          String[]       @default([])
  status        QuestionStatus @default(DRAFT)
  authorId      String?        @map("author_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  subject      Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic        Topic?        @relation(fields: [topicId], references: [id], onDelete: SetNull)
  author       User?         @relation(fields: [authorId], references: [id])
  quizLinks    QuizQuestion[]

  @@index([subjectId])
  @@index([topicId])
  @@index([status])
  @@index([type])
  @@map("questions")
}

model Quiz {
  id               String     @id @default(cuid())
  subjectId        String     @map("subject_id")
  title            String
  slug             String
  description      String?
  type             QuizType   @default(PRACTICE)
  timeLimitMinutes Int?       @map("time_limit_minutes")
  questionCount    Int        @default(10) @map("question_count")
  shuffleQuestions Boolean    @default(true) @map("shuffle_questions")
  shuffleOptions   Boolean    @default(true) @map("shuffle_options")
  allowBacktrack   Boolean    @default(true) @map("allow_backtrack")
  passingScore     Int        @default(50) @map("passing_score")
  status           QuizStatus @default(DRAFT)
  authorId         String?    @map("author_id")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  publishedAt      DateTime?  @map("published_at")

  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  author    User?          @relation(fields: [authorId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
  certificates QuizCertificate[]

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@index([status])
  @@index([type])
  @@map("quizzes")
}

model QuizQuestion {
  quizId      String @map("quiz_id")
  questionId  String @map("question_id")
  orderIndex  Int    @default(0) @map("order_index")

  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([quizId, questionId])
  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  quizId        String        @map("quiz_id")
  status        AttemptStatus @default(IN_PROGRESS)
  score         Int?
  correctCount  Int?          @map("correct_count")
  totalCount    Int           @map("total_count")
  answers       Json          @default("[]")
  questionOrder String[]      @default([]) @map("question_order")
  startedAt     DateTime      @default(now()) @map("started_at")
  submittedAt   DateTime?     @map("submitted_at")
  expiresAt     DateTime?     @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  certificate QuizCertificate?

  @@index([userId])
  @@index([quizId])
  @@index([status])
  @@map("quiz_attempts")
}

model QuizCertificate {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  attemptId String   @unique @map("attempt_id")
  quizId    String   @map("quiz_id")
  code      String   @unique
  score     Int
  issuedAt  DateTime @default(now()) @map("issued_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempt QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  quiz    Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quiz_certificates")
}
